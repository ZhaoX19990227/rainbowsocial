APP_ENV=development
SERVER_PORT=8088
DATABASE_PATH=./social_app.db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_HOURS=72
OTP_EXPIRY_MINUTES=5
ALLOWED_ORIGINS=*

# QQ Mail SMTP
SMTP_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code
SMTP_FROM=your_qq_email@qq.com
